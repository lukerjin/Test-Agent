# ============================================================
# Universal Test Agent — Environment Variables
# Copy this file to .env and fill in your values
#   cp .env.sample .env
# ============================================================

# ------------------------------------------------------------
# LLM API Keys — uncomment the one you use
# ------------------------------------------------------------

# Gemini (free tier available)
GEMINI_API_KEY=

# OpenAI
# OPENAI_API_KEY=

# DeepSeek
# DEEPSEEK_API_KEY=

# Groq
# GROQ_API_KEY=

# Together AI
# TOGETHER_API_KEY=

# OpenRouter
# OPENROUTER_API_KEY=

# Custom / any OpenAI-compatible API
# CUSTOM_API_KEY=

# ------------------------------------------------------------
# Database (MySQL) — passed to the DB MCP server
# ------------------------------------------------------------

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=

# ------------------------------------------------------------
# Test Accounts — used by the agent to log in during tests
# ------------------------------------------------------------

TEST_ADMIN_USER=
TEST_ADMIN_PASS=

TEST_USER_USER=
TEST_USER_PASS=
